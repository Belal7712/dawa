VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production public origin for guest invite links (e.g. https://dawatak.com).
# In DEV the app always uses the Vite Local URL (localhost) so you can test
# /invite/:token. For production builds, set this to your deployed React app
# origin — not a WordPress homepage that returns 404 on /invite/*.
VITE_PUBLIC_BASE_URL=https://dawatak.com
